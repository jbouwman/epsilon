(deftest test-xxh64-empty-seed0
  "XXH64 of empty input, seed 0"
  (let ((input (make-array 0 :element-type '(unsigned-byte 8))))
    (assert-= (xxh:xxh64 input) #xEF46DB3751D8E999)))

