;;;; Tests for xxHash implementation (XXH64 and XXH32)
;;;;
;;;; Test vectors from the xxHash reference implementation sanity check
;;;; (cli/xsum_sanity_check.c). The test buffer is generated by a PRNG
;;;; matching XSUM_fillTestBuffer.

(defpackage epsilon.ssl.xxhash-tests
  (:use :cl :epsilon.test :epsilon.ssl.test-support)
  (:local-nicknames
   (#:xxh #:epsilon.ssl.xxhash))
  (:enter t))

(in-package :epsilon.ssl.xxhash-tests)

;;; ---------------------------------------------------------------------------
;;; Helper functions
;;; ---------------------------------------------------------------------------

(defun make-test-buffer (len)
  "Generate the canonical xxHash test buffer (port of XSUM_fillTestBuffer).
   Uses a multiplicative PRNG: byteGen starts at PRIME32, each byte is
   byteGen>>56, then byteGen *= PRIME64."
  (let ((buf (make-array len :element-type '(unsigned-byte 8)))
        (byte-gen #x9E3779B1)
        (prime64  #x9E3779B185EBCA8D)
        (mask     #xFFFFFFFFFFFFFFFF))
    (loop for i from 0 below len
          do (setf (aref buf i) (logand #xFF (ash byte-gen -56)))
             (setf byte-gen (logand mask (* byte-gen prime64))))
    buf))

