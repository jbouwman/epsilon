               (xxh:xxh32-update state data :start 0 :end split)
               (xxh:xxh32-update state data :start split)
               (assert-= (xxh:xxh32-finalize state) expected)))))

;;; ---------------------------------------------------------------------------
;;; State copy tests
;;; ---------------------------------------------------------------------------

(deftest test-xxh64-copy
  "Copying XXH64 state should produce independent hasher"
  (let* ((data1 (string-to-bytes "Hello"))
         (data2a (string-to-bytes ", World!"))
         (data2b (string-to-bytes ", Lisp!"))
         (state1 (xxh:make-xxh64-state)))
    (xxh:xxh64-update state1 data1)
    (let ((state2 (xxh:xxh64-copy state1)))
      (xxh:xxh64-update state1 data2a)
      (xxh:xxh64-update state2 data2b)
      (let ((result1 (xxh:xxh64-finalize state1))
            (result2 (xxh:xxh64-finalize state2))
            (expected1 (xxh:xxh64 (string-to-bytes "Hello, World!")))
            (expected2 (xxh:xxh64 (string-to-bytes "Hello, Lisp!"))))
        (assert-= result1 expected1)
        (assert-= result2 expected2)
        (assert-not (= result1 result2))))))

(deftest test-xxh32-copy
  "Copying XXH32 state should produce independent hasher"
  (let* ((data1 (string-to-bytes "Hello"))
         (data2a (string-to-bytes ", World!"))
         (data2b (string-to-bytes ", Lisp!"))
         (state1 (xxh:make-xxh32-state)))
    (xxh:xxh32-update state1 data1)
    (let ((state2 (xxh:xxh32-copy state1)))
      (xxh:xxh32-update state1 data2a)
      (xxh:xxh32-update state2 data2b)
      (let ((result1 (xxh:xxh32-finalize state1))
            (result2 (xxh:xxh32-finalize state2))
            (expected1 (xxh:xxh32 (string-to-bytes "Hello, World!")))
            (expected2 (xxh:xxh32 (string-to-bytes "Hello, Lisp!"))))
        (assert-= result1 expected1)
        (assert-= result2 expected2)
        (assert-not (= result1 result2))))))

;;; ---------------------------------------------------------------------------
;;; Edge cases
;;; ---------------------------------------------------------------------------

(deftest test-xxh64-exact-stripe-size
  "XXH64 of exactly 32 bytes (one stripe, no remainder)"
  (let* ((data (make-test-buffer 32))
         (result (xxh:xxh64 data)))
    ;; Verify deterministic
    (assert-= result (xxh:xxh64 data))))

(deftest test-xxh64-stripe-plus-one
  "XXH64 of 33 bytes (one stripe + 1 byte remainder)"
  (let* ((data (make-test-buffer 33))
         (result (xxh:xxh64 data)))
    (assert-= result (xxh:xxh64 data))
    ;; Incremental should match
    (let ((state (xxh:make-xxh64-state)))
      (xxh:xxh64-update state data :start 0 :end 32)
      (xxh:xxh64-update state data :start 32)
      (assert-= (xxh:xxh64-finalize state) result))))

(deftest test-xxh32-exact-stripe-size
  "XXH32 of exactly 16 bytes (one stripe, no remainder)"
  (let* ((data (make-test-buffer 16))
         (result (xxh:xxh32 data)))
    (assert-= result (xxh:xxh32 data))))

(deftest test-xxh32-stripe-plus-one
  "XXH32 of 17 bytes (one stripe + 1 byte remainder)"
  (let* ((data (make-test-buffer 17))
         (result (xxh:xxh32 data)))
    (assert-= result (xxh:xxh32 data))
    (let ((state (xxh:make-xxh32-state)))
      (xxh:xxh32-update state data :start 0 :end 16)
      (xxh:xxh32-update state data :start 16)
      (assert-= (xxh:xxh32-finalize state) result))))

(deftest test-xxh64-large-input
  "XXH64 of 1000 bytes should be deterministic"
  (let* ((data (make-test-buffer 1000))
         (result (xxh:xxh64 data)))
    (assert-= result (xxh:xxh64 data))))

(deftest test-xxh32-large-input
  "XXH32 of 1000 bytes should be deterministic"
  (let* ((data (make-test-buffer 1000))
         (result (xxh:xxh32 data)))
    (assert-= result (xxh:xxh32 data))))

(deftest test-xxh64-seeded-incremental
  "Seeded incremental XXH64 should match seeded one-shot"
  (let* ((data (make-test-buffer 222))
         (seed 2654435761)
         (oneshot (xxh:xxh64 data :seed seed))
         (state (xxh:make-xxh64-state :seed seed)))
    (xxh:xxh64-update state data :start 0 :end 50)
    (xxh:xxh64-update state data :start 50 :end 100)
    (xxh:xxh64-update state data :start 100)
    (assert-= (xxh:xxh64-finalize state) oneshot)))

(deftest test-xxh32-seeded-incremental
  "Seeded incremental XXH32 should match seeded one-shot"
  (let* ((data (make-test-buffer 222))
         (seed 2654435761)
         (oneshot (xxh:xxh32 data :seed seed))
         (state (xxh:make-xxh32-state :seed seed)))
    (xxh:xxh32-update state data :start 0 :end 50)
    (xxh:xxh32-update state data :start 50 :end 100)
    (xxh:xxh32-update state data :start 100)
    (assert-= (xxh:xxh32-finalize state) oneshot)))

(deftest test-xxh64-start-end
  "XXH64 :start/:end should hash the subrange"
  (let* ((data (make-test-buffer 100))
         (sub (subseq data 10 60))
         (result-sub (xxh:xxh64 sub))
         (result-range (xxh:xxh64 data :start 10 :end 60)))
    (assert-= result-sub result-range)))

(deftest test-xxh32-start-end
  "XXH32 :start/:end should hash the subrange"
  (let* ((data (make-test-buffer 100))
         (sub (subseq data 10 60))
         (result-sub (xxh:xxh32 sub))
         (result-range (xxh:xxh32 data :start 10 :end 60)))
    (assert-= result-sub result-range)))
