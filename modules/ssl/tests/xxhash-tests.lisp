;;; ---------------------------------------------------------------------------
;;; Incremental hashing tests
;;; ---------------------------------------------------------------------------

(deftest test-xxh64-incremental-byte-by-byte
  "Incremental XXH64 byte-by-byte should match one-shot"
  (let* ((data (make-test-buffer 222))
         (oneshot (xxh:xxh64 data))
         (state (xxh:make-xxh64-state)))
    (loop for i from 0 below (length data)
          do (xxh:xxh64-update state data :start i :end (1+ i)))
    (assert-= (xxh:xxh64-finalize state) oneshot)))

(deftest test-xxh64-incremental-split
  "Incremental XXH64 with data split at every position"
  (let* ((data (make-test-buffer 100))
         (expected (xxh:xxh64 data)))
    (loop for split from 0 to (length data)
          do (let ((state (xxh:make-xxh64-state)))
               (xxh:xxh64-update state data :start 0 :end split)
               (xxh:xxh64-update state data :start split)
               (assert-= (xxh:xxh64-finalize state) expected)))))

(deftest test-xxh32-incremental-byte-by-byte
  "Incremental XXH32 byte-by-byte should match one-shot"
  (let* ((data (make-test-buffer 222))
         (oneshot (xxh:xxh32 data))
         (state (xxh:make-xxh32-state)))
    (loop for i from 0 below (length data)
          do (xxh:xxh32-update state data :start i :end (1+ i)))
    (assert-= (xxh:xxh32-finalize state) oneshot)))

(deftest test-xxh32-incremental-split
  "Incremental XXH32 with data split at every position"
  (let* ((data (make-test-buffer 50))
         (expected (xxh:xxh32 data)))
